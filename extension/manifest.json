{
  "manifest_version": 3,
  "name": "淘系推广参谋·商品导入",
  "version": "2.4",
  "description": "在淘宝/天猫商品页注入悬浮按钮，一键提取标题/价格/主图并导入本地推广参谋工具（普通扩展，无需 Tampermonkey）",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://*.tmall.hk/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:8123/*",
        "https://*.taobao.com/*",
        "https://*.tmall.com/*",
        "https://*.tmall.hk/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "导入推广参谋"
  }
}
